{
  "version": 2,
  "name": "seedmind",
  "builds": [
    { "src": "apps/client/*.html",           "use": "@vercel/static" },
    { "src": "apps/client/styles.css",       "use": "@vercel/static" },
    { "src": "apps/client/script.js",        "use": "@vercel/static" },
    { "src": "packages/theme/tokens.css",    "use": "@vercel/static" },
    { "src": "apps/orchestrator/api/ask.js", "use": "@vercel/node"   }
  ],
  "routes": [
    { "src": "/ask",          "dest": "/apps/orchestrator/api/ask.js" },
    { "src": "/styles.css",   "dest": "/apps/client/styles.css"       },
    { "src": "/script.js",    "dest": "/apps/client/script.js"        },
    { "src": "/(.*\\.html)",  "dest": "/apps/client/$1"               },
    { "src": "/app",          "dest": "/apps/client/app.html"         },
    { "src": "/app/",         "dest": "/apps/client/app.html"         },
    { "src": "/",             "dest": "/apps/client/hero.html"        },
    { "src": "/(.*)",         "dest": "/$1"                           }
  ],
  "env": {
    "MEMORY_URL": "https://seedmind-memory.onrender.com/api/memory",
    "LLM_URL":    "https://api.openai.com/v1/chat/completions",
    "LLM_KEY":    "@llm_key"
  }
}
