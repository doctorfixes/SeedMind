    "test:shared": "node --test packages/shared/__tests__/shared.test.js packages/shared/__tests__/shared.expanded.test.js",
    "test:orchestrator": "node --test apps/orchestrator/__tests__/extractSignals.test.js apps/orchestrator/__tests__/updateGrowthRings.test.js apps/orchestrator/__tests__/ask.test.js",
